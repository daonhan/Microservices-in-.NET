        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "100 * sum by (instance) (rate(http_server_request_duration_seconds_count{job=\"microservices\", http_response_status_code=~\"5..\"}[$__rate_interval])) / sum by (instance) (rate(http_server_request_duration_seconds_count{job=\"microservices\"}[$__rate_interval]))",
