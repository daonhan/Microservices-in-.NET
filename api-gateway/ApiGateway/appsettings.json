{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "AuthMicroserviceBaseAddress": "http://localhost:8003"
  },
  "OpenTelemetry": {
    "OtlpExporterEndpoint": "http://host.docker.internal:4317",
    "SamplingRatio": 1.0,
    "Environment": "Development",
    "ServiceVersion": "1.0.0",
    "EnableConsoleExporters": false
  }
}
