{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Provider": "Ocelot"
  },
  "Authentication": {
    "AuthMicroserviceBaseAddress": "http://localhost:8003"
  },
  "ReverseProxy": {
    "Routes": {
      "login": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/login",
          "Methods": [ "POST" ]
        }
      },
      "product-read": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/product/{id}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/{id}" }
        ]
      },
      "basket": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/basket/{**rest}",
          "Methods": [ "GET", "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "order": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/order/{**rest}",
          "Methods": [ "GET", "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "inventory-backorder": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/inventory/{productId}/backorder",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{productId}/backorder" }
        ]
      },
      "inventory-read": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/inventory/{**rest}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://auth-clusterip-service:8080"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://product-clusterip-service:8080"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://basket-clusterip-service:8080"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://order-clusterip-service:8080"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://inventory-clusterip-service:8080"
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "OtlpExporterEndpoint": "http://host.docker.internal:4317",
    "SamplingRatio": 1.0,
    "Environment": "Development",
    "ServiceVersion": "1.0.0",
    "EnableConsoleExporters": false
  }
}
