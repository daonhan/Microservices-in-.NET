{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Provider": "Yarp"
  },
  "Authentication": {
    "AuthMicroserviceBaseAddress": "http://localhost:8003"
  },
  "ReverseProxy": {
    "Routes": {
      "login": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/login",
          "Methods": [ "POST" ]
        }
      },
      "product-read": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/product/{id}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/{id}" }
        ]
      },
      "product-write": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/product/{**rest}",
          "Methods": [ "POST", "PUT" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "basket": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/basket/{**rest}",
          "Methods": [ "GET", "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "order": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/order/{**rest}",
          "Methods": [ "GET", "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "inventory-backorder": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/inventory/{productId}/backorder",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{productId}/backorder" }
        ]
      },
      "inventory-list": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/inventory",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/" }
        ]
      },
      "inventory-read": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/inventory/{**rest}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "inventory-write": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/inventory/{**rest}",
          "Methods": [ "POST", "PUT" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "shipping": {
        "ClusterId": "shipping-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/shipping/{**rest}",
          "Methods": [ "GET", "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "payment-admin-write": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/payment/{**rest}",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "payment-read": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/payment/{**rest}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/{**rest}" }
        ]
      },
      "swagger-auth-spec": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/auth/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-product-spec": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/product/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-basket-spec": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/basket/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-order-spec": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/order/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-inventory-spec": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/inventory/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-shipping-spec": {
        "ClusterId": "shipping-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/shipping/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      },
      "swagger-payment-spec": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/swagger/payment/v1/swagger.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/swagger/v1/swagger.json" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://auth-clusterip-service:8080"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://product-clusterip-service:8080"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://basket-clusterip-service:8080"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://order-clusterip-service:8080"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://inventory-clusterip-service:8080"
          }
        }
      },
      "shipping-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://shipping-clusterip-service:8080"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://payment-clusterip-service:8080"
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "OtlpExporterEndpoint": "http://host.docker.internal:4317",
    "SamplingRatio": 1.0,
    "Environment": "Development",
    "ServiceVersion": "1.0.0",
    "EnableConsoleExporters": false
  }
}
